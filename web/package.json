{
  "name": "dropcore",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "predeploy": "npm run typecheck && npm run build",
    "predeploy:full": "npm run typecheck && npm run lint && npm run test && npm run build",
    "deploy:vercel": "node scripts/assert-vercel-dropcore-web.mjs && cd .. && npm exec --prefix web vercel -- deploy --prod --yes",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.49.1",
    "next": "^15.5.10",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "19.2.9",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "vercel": "^53.3.2",
    "vitest": "^2.1.9"
  }
}
